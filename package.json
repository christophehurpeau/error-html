{
  "name": "error-html",
  "version": "0.4.1",
  "description": "render error stack in html",
  "keywords": [],
  "homepage": "https://github.com/christophehurpeau/error-html",
  "bugs": {
    "url": "https://github.com/christophehurpeau/error-html/issues"
  },
  "license": "ISC",
  "author": "Christophe Hurpeau <christophe@hurpeau.com> (https://christophe.hurpeau.com)",
  "repository": "https://github.com/christophehurpeau/error-html.git",
  "files": [
    "src",
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index-node22.mjs",
  "module": "./dist/index-browser.es.js",
  "browser": "./dist/index-browser.es.js",
  "types": "./dist/definitions/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/definitions/src/index.d.ts",
      "node": {
        "import": "./dist/index-node22.mjs"
      }
    }
  },
  "scripts": {
    "build": "pnpm run clean:build && rollup --config rollup.config.mjs && pnpm run build:definitions",
    "build:definitions": "tsc -p tsconfig.json",
    "checks": "node scripts/check-package.ts",
    "clean": "rm -Rf docs dist",
    "clean:build": "pob-esbuild-clean-out dist",
    "format": "oxfmt",
    "format:check": "oxfmt --check .",
    "generate:api": "typedoc --tsconfig tsconfig.doc.json",
    "lint": "pnpm run format && tsc && pnpm run lint:eslint",
    "lint:eslint": "eslint --quiet .",
    "prepare": "pob-root-postinstall",
    "preview": "node scripts/preview.ts",
    "test": "TZ=UTC node --test 'src/**/*.test.ts'",
    "test:coverage": "TZ=UTC npx c8 --all --src ./src node --test 'src/**/*.test.ts'",
    "test:coverage:generate": "TZ=UTC npx c8 --reporter=json --all --src ./src node --test 'src/**/*.test.ts'",
    "test:e2e": "playwright test -c e2e/playwright.config.ts",
    "test:watch": "TZ=UTC node --test 'src/**/*.test.ts'",
    "tsc": "tsc",
    "watch": "pob-watch"
  },
  "dependencies": {
    "errorstacks": "^2.4.2",
    "escape-goat": "^4.0.0",
    "highlight.js": "^11.11.1"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@pob/eslint-config": "65.5.0",
    "@pob/rollup-esbuild": "9.1.2",
    "@pob/root": "24.5.0",
    "@types/node": "26.1.1",
    "check-package-dependencies": "11.1.1",
    "eslint": "10.4.0",
    "typedoc": "0.28.19",
    "typescript": "6.0.3"
  },
  "commitlint": {
    "extends": [
      "@pob/root/commitlint-config"
    ]
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "pob": {
    "bundler": "rollup-esbuild",
    "entries": [
      "index"
    ],
    "envs": [
      {
        "target": "node",
        "version": "22"
      }
    ],
    "typescript": true
  }
}
